# DevOps Console configuration (copy to .env and fill in)

# Base domain. The console lives at https://<CONSOLE_SUBDOMAIN>.<DOMAIN>,
# proxied dev servers at https://<slug>.<DOMAIN>.
DOMAIN=vr.ae
CONSOLE_SUBDOMAIN=console

# Public listeners (the app terminates TLS itself).
HTTP_PORT=80
HTTPS_PORT=443

# Wildcard certificate for *.DOMAIN (+ apex), provisioned out-of-band via
# Let's Encrypt DNS-01 (see README "TLS certificate runbook"). The app
# hot-reloads these files when they change on disk.
TLS_CERT_FILE=/etc/letsencrypt/live/vr.ae/fullchain.pem
TLS_KEY_FILE=/etc/letsencrypt/live/vr.ae/privkey.pem

# Google OAuth 2.0 / OIDC web client (Google Cloud Console -> APIs & Services
# -> Credentials). Authorized redirect URI:
#   https://<CONSOLE_SUBDOMAIN>.<DOMAIN>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OIDC issuer; only override for testing against a local issuer.
OIDC_ISSUER=https://accounts.google.com

# Comma-separated Google account emails allowed to sign in.
ALLOWED_EMAILS=ja@vr.ae

# 64 hex chars used to sign session cookies:  openssl rand -hex 32
SESSION_SECRET=
# Session lifetime in hours.
SESSION_TTL_HOURS=168

# Coordinator control engine (loopback HTTP API of dev_coordinator.py).
COORDINATOR_URL=http://127.0.0.1:29876
# Production uses the dedicated dev-coordinator.service and must not spawn a
# detached duplicate. Local development may opt in explicitly.
COORDINATOR_AUTOSTART=0
# Private bearer credential created by the coordinator (mode 0600). It is read
# only by the server-side Console process and never sent to browser JavaScript.
COORDINATOR_TOKEN_FILE=~/.codex/agent-coordinator/api-token
# Shared coordinator state location.
CODEX_AGENT_COORDINATOR_HOME=~/.codex/agent-coordinator
# Override only when the repository is not at DEVCOORDINATOR_ROOT.
# COORDINATOR_SCRIPT=/absolute/path/to/DevCoordinator/skills/codex-dev-coordinator/scripts/dev_coordinator.py

# CPU/memory sampling cadence (ms) for the history charts on the console.
# Every sample reads coordinator inventory (shells out to `docker stats` when
# Docker is present). Default 10000; values below 2000 are rejected.
# METRICS_INTERVAL_MS=10000

# Where the console keeps its own state (subdomain routes, etc.).
STATE_DIR=~/.local/state/devops-console

# Directory the plain-HTTP :80 listener serves ACME HTTP-01 challenges from,
# so certbot --webroot can issue/renew certs while the app owns port 80.
# Default: <STATE_DIR>/acme
ACME_WEBROOT=~/.local/state/devops-console/acme

LOG_LEVEL=info
